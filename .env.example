# ==========================================================================
# Vibrato Motos — variáveis de ambiente
# Copie para .env (local) ou configure no painel da Vercel (produção).
# ==========================================================================

# === Banco de dados (PostgreSQL) ===
# LOCAL (docker-compose):
DATABASE_URL="postgresql://vibrato:vibrato@localhost:5433/vibrato?schema=public"
# PRODUÇÃO (Supabase): use a "Connection string" do projeto (Settings > Database).
# Prefira a porta 6543 (pooler / Transaction) para serverless na Vercel, ex.:
# DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require"

# === Sessão ===
# Segredo para assinar o cookie de sessão. GERE UM NOVO em produção:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET="troque-este-segredo-em-producao"

# === Storage (S3-compatível) ===
# LOCAL = MinIO (docker-compose):
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="vibrato"
S3_ACCESS_KEY_ID="vibrato"
S3_SECRET_ACCESS_KEY="vibrato123"
S3_FORCE_PATH_STYLE="true"
#
# PRODUÇÃO = Supabase Storage (Storage > S3 Connection / Access keys):
#   1. Crie um bucket (ex.: "vibrato"), PRIVADO.
#   2. Ative "S3 protocol connection" e gere uma Access key.
#   Depois preencha:
# S3_ENDPOINT="https://<ref>.storage.supabase.co/storage/v1/s3"
# S3_REGION="sa-east-1"                 # a região mostrada no painel
# S3_BUCKET="vibrato"                   # o nome do bucket criado
# S3_ACCESS_KEY_ID="<Access key ID>"
# S3_SECRET_ACCESS_KEY="<Secret access key>"
# S3_FORCE_PATH_STYLE="true"            # mantém true (Supabase usa path-style)
